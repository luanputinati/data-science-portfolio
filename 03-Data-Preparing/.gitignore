# Raw datasets containing identifying information
data/raw/*
!data/raw/.gitkeep

# Processed datasets generated by the pipeline
data/processed/*
!data/processed/.gitkeep

# Python cache and compiled files
__pycache__/
*.py[cod]

# Development and analysis caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environment variables
.env
.env.*

# Operating system files
.DS_Store
Thumbs.db